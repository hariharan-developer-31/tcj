<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <rect width="200" height="200" fill="#000" rx="24" stroke="#333" stroke-width="1.5" />
  <g transform="translate(100,100)">
    <!-- Google Bard/Gemini four-point sparkle star in clean monochrome outline -->
    <path d="M 0,-50 C 0,-15 15,0 50,0 C 15,0 0,15 0,50 C 0,15 -15,0 -50,0 C -15,0 0,-15 0,-50 Z" fill="none" stroke="#fff" stroke-width="2.5" />
    <circle cx="0" cy="0" r="12" fill="none" stroke="#fff" stroke-width="1" stroke-dasharray="2 2" />
    <!-- Secondary spark -->
    <g transform="translate(30, -35) scale(0.4)">
      <path d="M 0,-50 C 0,-15 15,0 50,0 C 15,0 0,15 0,50 C 0,15 -15,0 -50,0 C -15,0 0,-15 0,-50 Z" fill="#fff" />
    </g>
    <!-- Accent circles -->
    <circle cx="0" cy="0" r="58" fill="none" stroke="#fff" stroke-width="0.75" opacity="0.2" />
  </g>
</svg>
