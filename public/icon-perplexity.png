<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <rect width="200" height="200" fill="#000" rx="24" stroke="#333" stroke-width="1.5" />
  <g transform="translate(100,100)">
    <!-- Perplexity style: Concentric geometric rings/infinity loop -->
    <path d="M -30,-30 L 30,30 M -30,30 L 30,-30" stroke="#fff" stroke-width="1.5" opacity="0.3" />
    <circle cx="0" cy="0" r="30" fill="none" stroke="#fff" stroke-width="2" />
    <circle cx="0" cy="0" r="15" fill="none" stroke="#fff" stroke-width="1" stroke-dasharray="2 2" />
    <path d="M-45,0 A45,45 0 0,1 45,0" fill="none" stroke="#fff" stroke-width="2" stroke-dasharray="6 4" />
    <path d="M-45,0 A45,45 0 0,0 45,0" fill="none" stroke="#fff" stroke-width="1.5" opacity="0.5" />
    <!-- Outer accent rings -->
    <circle cx="0" cy="0" r="60" fill="none" stroke="#fff" stroke-width="0.75" opacity="0.2" />
  </g>
</svg>
